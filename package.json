{
  "name": "toy-element",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "init": "bash ./init.shell",
    "install:all": "corepack pnpm install",
    "dev": "corepack pnpm --filter @toy-element/play dev",
    "docs:dev": "corepack pnpm --filter @toy-element/docs dev",
    "docs:build": "corepack pnpm --filter @toy-element/docs build",
    "test":"echo 'todo'",
    "build:play": "corepack pnpm --filter @toy-element/play build",
    "typecheck:play": "corepack pnpm --filter @toy-element/play exec vue-tsc --noEmit",
    "typecheck:core": "corepack pnpm exec tsc -p packages/core/tsconfig.json --noEmit",
    "typecheck:components": "corepack pnpm exec tsc -p packages/components/tsconfig.json --noEmit",
    "typecheck:utils": "corepack pnpm exec tsc -p packages/utils/tsconfig.json --noEmit",
    "typecheck": "corepack pnpm run typecheck:play && corepack pnpm run typecheck:components && corepack pnpm run typecheck:core && corepack pnpm run typecheck:utils"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "@types/node": "20.11.20",
    "@vitejs/plugin-vue": "5.0.4",
    "@vitejs/plugin-vue-jsx": "3.1.0",
    "@vue/tsconfig": "0.5.1",
    "postcss-color-mix": "1.1.0",
    "postcss-each": "1.1.0",
    "postcss-each-variables": "0.3.0",
    "postcss-for": "2.1.1",
    "postcss-nested": "6.0.1",
    "typescript": "5.2.2",
    "vite": "5.1.4",
    "vitest": "1.4.0",
    "vue-tsc": "1.8.27"
  }
}

