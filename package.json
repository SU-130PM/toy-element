{
  "name": "toy-element",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "init": "bash ./init.shell",
    "install:all": "corepack pnpm install",
    "dev": "corepack pnpm --filter @su-130pm/play dev",
    "docs:dev": "corepack pnpm --filter @su-130pm/docs dev",
    "docs:build": "corepack pnpm --filter @su-130pm/docs build",
    "test": "corepack pnpm --filter @su-130pm/components test",
    "build:play": "corepack pnpm --filter @su-130pm/play build",
    "build:packages": "node ./scripts/build-packages.mjs",
    "release": "corepack pnpm run test && corepack pnpm run build:packages",
    "publish:utils": "corepack pnpm publish ./packages/utils/dist --access public --no-git-checks",
    "publish:theme": "corepack pnpm publish ./packages/theme/dist --access public --no-git-checks",
    "publish:components": "corepack pnpm publish ./packages/components/dist --access public --no-git-checks",
    "publish:core": "corepack pnpm publish ./packages/core/dist --access public --no-git-checks",
    "publish:packages": "corepack pnpm run publish:utils && corepack pnpm run publish:theme && corepack pnpm run publish:components && corepack pnpm run publish:core",
    "publish:release": "corepack pnpm run release && corepack pnpm run publish:packages"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.0.4",
    "@vitejs/plugin-vue-jsx": "3.1.0",
    "postcss-color-mix": "1.1.0",
    "postcss-each": "1.1.0",
    "postcss-each-variables": "0.3.0",
    "postcss-for": "2.1.1",
    "postcss-nested": "6.0.1",
    "vite": "5.1.4",
    "vitest": "1.4.0"
  }
}

